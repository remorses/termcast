{
  "$schema": "https://unpkg.com/@holocron.so/vite/src/schema.json",
  "name": "Termcast",
  "description": "Build terminal apps with React and Raycast-like APIs",
  "favicon": "/favicon.ico",
  "colors": {
    "primary": "#fe750e"
  },
  "appearance": {
    "default": "dark"
  },
  "icons": {
    "library": "lucide"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/remorses/termcast"
      }
    ]
  },
  "navigation": {
