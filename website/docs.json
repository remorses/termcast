      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/remorses/termcast",
          "icon": "github"
        },
        {
          "anchor": "npm",
          "href": "https://www.npmjs.com/package/termcast",
          "icon": "package"
        },
        {
          "anchor": "Changelog",
          "href": "https://github.com/remorses/termcast/blob/main/termcast/CHANGELOG.md",
          "icon": "history"
        }
      ]
    },
    "groups": [
      {
        "group": "Overview",
