{
  "name": "termcast",
  "version": "1.4.0",
  "description": "Raycast for the terminal",
  "repository": "https://github.com/remorses/termcast",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "bun x tsc && chmod +x dist/cli.js",
    "release": "cd .. && bun changeset version && /Users/morse/Documents/GitHub/changesets/packages/cli/bin.js publish # my own fork to support github releases",
    "see-raycast-types": "zed node_modules/@raycast/api/types/index.d.ts",
    "play": "bun src/cli.tsx",
    "test": "bun test && bun e2e",
    "e2e": "vitest -u"
  },
  "bin": {
    "termcast": "./dist/cli.js"
  },
  "imports": {
    "#platform/cache": {
      "bun": "./src/platform/node/cache.ts",
      "node": {
        "types": "./dist/platform/node/cache.d.ts",
        "default": "./dist/platform/node/cache.js"
      },
      "browser": "./src/platform/browser/cache.ts",
      "default": {
        "types": "./dist/platform/node/cache.d.ts",
        "default": "./dist/platform/node/cache.js"
      }
    },
    "#platform/localstorage": {
      "bun": "./src/platform/node/localstorage.ts",
      "node": {
        "types": "./dist/platform/node/localstorage.d.ts",
        "default": "./dist/platform/node/localstorage.js"
      },
      "browser": "./src/platform/browser/localstorage.ts",
      "default": {
        "types": "./dist/platform/node/localstorage.d.ts",
        "default": "./dist/platform/node/localstorage.js"
      }
    },
    "#platform/runtime": {
      "bun": "./src/platform/node/runtime.ts",
      "node": {
        "types": "./dist/platform/node/runtime.d.ts",
        "default": "./dist/platform/node/runtime.js"
      },
      "browser": "./src/platform/browser/runtime.ts",
      "default": {
        "types": "./dist/platform/node/runtime.d.ts",
        "default": "./dist/platform/node/runtime.js"
      }
    },
    "#sqlite": {
      "bun": "./src/platform/bun/sqlite.ts",
      "node": {
        "types": "./dist/platform/node/sqlite.d.ts",
        "default": "./dist/platform/node/sqlite.js"
      },
      "default": {
        "types": "./dist/platform/node/sqlite.d.ts",
        "default": "./dist/platform/node/sqlite.js"
      }
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.tsx",
      "default": "./dist/index.js"
    },
    "./opentui": {
      "types": "./dist/opentui.d.ts",
      "bun": "./src/opentui.tsx",
      "default": "./dist/opentui.js"
    },
    "./src/*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.tsx"
    }
  },
  "files": [
    "dist",
    "src",
    "esm",
    "fonts"
  ],
  "keywords": [],
  "author": "Tommaso De Rossi, morse <beats.by.morse@gmail.com>",
  "license": "",
  "dependencies": {
    "@parcel/watcher": "^2.5.6",
    "@tanstack/react-query": "^5.85.5",
    "@tanstack/react-query-persist-client": "^5.85.5",
    "@termcast/utils": "workspace:^",
    "change-case": "^5.4.4",
    "colord": "^2.9.3",
    "goke": "^6.6.0",
    "google-auth-library": "^10.3.0",
    "jszip": "^3.10.1",
    "marked": "^17.0.2",
    "nanoid": "^5.1.5",
    "node-diff3": "^3.2.0",
    "react-hook-form": "^7.62.0",
    "react-refresh": "^0.18.0",
    "simple-plist": "^1.3.1",
    "string-dedent": "^3.0.2",
    "better-sqlite3": "^12.8.0",
    "zustand": "^5.0.8"
  },
  "peerDependencies": {
    "@opentui/core": "^0.1.102",
    "@opentui/react": "^0.1.102",
    "react": "*"
  },
  "devDependencies": {
    "@opentui/core": "^0.1.102",
    "@opentui/react": "^0.1.102",
    "@raycast/api": "^1.102.5",
    "@raycast/utils": "^2.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.2.3",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/headless": "^5.5.0",
    "bun-pty": "0.4.8",
    "zigpty": "^0.0.4",
    "react": "^19.2.4",
    "tuistory": "workspace:^",
    "vitest": "^4.0.16"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  }
}
